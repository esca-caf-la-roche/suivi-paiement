# ─────────────────────────────────────────────────────────────────────────────
# Supabase — Frontend (exposées au navigateur, préfixe VITE_ obligatoire)
# ─────────────────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# ─────────────────────────────────────────────────────────────────────────────
# HelloAsso — Edge Functions UNIQUEMENT (jamais côté navigateur !)
# Ces variables sont définies dans : Supabase Dashboard → Settings → Edge Functions
# ─────────────────────────────────────────────────────────────────────────────
HELLOASSO_CLIENT_ID=<your-helloasso-client-id>
HELLOASSO_CLIENT_SECRET=<your-helloasso-client-secret>
HELLOASSO_ORG_SLUG=caf-la-roche-bonneville
